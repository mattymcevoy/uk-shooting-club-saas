generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Multi-Tenant Architecture
// ==========================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  themeColor  String?  @default("#10b981") // emerald-500
  
  // B2B Stripe SaaS Subscription
  stripeCustomerId       String? @unique
  stripeSubscriptionId   String? @unique
  subscriptionStatus     SubscriptionStatus @default(TRIALING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  facilities  Facility[]
  events      Event[]
  bookings    Booking[]
  invoices    Invoice[]
  subscriptions Subscription[]
  membershipPlans MembershipPlan[]
}

// ==========================================
// Base & Membership Models
// ==========================================

enum MembershipTier {
  GUEST
  PROBATIONARY
  FULL_MEMBER
  JUNIOR
  VIP
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  IN_ARREARS
}

model User {
  id        String   @id @default(cuid())
  
  // Tenant Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A User is unique per email *per organization*
  // This allows a shooter to be a member of two different clubs with the same email
  email     String
  @@unique([email, organizationId])

  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Membership & Financials
  membershipTier   MembershipTier @default(GUEST)
  status           AccountStatus  @default(ACTIVE)
  stripeCustomerId String?        

  // New Membership Properties
  isLicenseHolder      Boolean @default(false)
  isRegisteredShooter  Boolean @default(false)
  address              String?
  certificateNumber    String?
  
  // File Upload References (Vercel Blob URLs)
  profilePhotoUrl      String?
  certificateUrl       String?
  gunLicenseUrl        String?

  // Security Hash for Membership QR
  qrHash               String? @unique

  // Relations
  subscriptions Subscription[]
  invoices      Invoice[]
  bookings      Booking[]
}

// ==========================================
// Financial & Billing Models
// ==========================================

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model Subscription {
  id     String @id @default(cuid())
  userId String 
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String             @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, organizationId])
}

enum InvoiceStatus {
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Invoice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stripeInvoiceId String?       @unique
  amount          Int // Stored in smallest currency unit (e.g., pence)
  currency        String        @default("GBP")
  status          InvoiceStatus @default(OPEN)
  description     String?

  createdAt DateTime @default(now())
}

// ==========================================
// Facility & Booking Models
// ==========================================

model Facility {
  id          String  @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  description String?
  capacity    Int     @default(1) // Number of lanes, pegs, or total slots

  // Pricing (in pence)
  baseRate   Int @default(0) // Rate for Guests/Probationary
  memberRate Int @default(0) // Discounted rate for Full Members

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
}

model Booking {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id])

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)

  paymentIntentId String? // Stripe PaymentIntent for standalone bookings
  amountPaid      Int     @default(0)
  
  // Event specific QR hash
  qrHash          String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facilityId, startTime, endTime])
}

// ==========================================
// Event & CRM Models
// ==========================================

model Event {
  id          String   @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title       String
  description String?
  date        DateTime
  maxAttendees Int?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// Phase 9: Dynamic Subscription Pricing
// ==========================================

model PlatformPlan {
  id          String   @id @default(cuid())
  name        String   // e.g "Standard SaaS License"
  description String?
  
  monthlyPrice Int      // Stored in pence (£199.00 = 19900)
  annualPrice  Int      // Stored in pence (£1900.00 = 190000)
  
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MembershipPlan {
  id          String   @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name        String   // e.g "Full Member", "VIP", "Junior"
  description String?
  
  monthlyPrice Int      // Stored in pence (£45.00 = 4500)
  annualPrice  Int      // Stored in pence (£450.00 = 45000)
  
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([name, organizationId])
}
