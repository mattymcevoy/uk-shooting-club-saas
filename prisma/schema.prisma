generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Multi-Tenant Architecture
// ==========================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  themeColor  String?  @default("#10b981") // emerald-500
  
  // B2B Stripe SaaS Subscription
  stripeCustomerId       String? @unique
  stripeSubscriptionId   String? @unique
  subscriptionStatus     SubscriptionStatus @default(TRIALING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  facilities  Facility[]
  events      Event[]
  bookings    Booking[]
  invoices    Invoice[]
  subscriptions Subscription[]
  membershipPlans MembershipPlan[]
  waitlistEntries WaitlistEntry[]
  locations   Location[]
  recurringTemplates RecurringBookingTemplate[]
  leaderboardSeasons LeaderboardSeason[]
  lessonPackages LessonPackage[]
  coachingSessions CoachingSession[]
  complianceDocuments ComplianceDocument[]
  incidents IncidentLog[]
  commCampaigns CommunicationCampaign[]
  privacyRequests PrivacyRequest[]
}

// ==========================================
// Base & Membership Models
// ==========================================

enum MembershipTier {
  GUEST
  PROBATIONARY
  FULL_MEMBER
  JUNIOR
  VIP
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  IN_ARREARS
}

enum UserRole {
  MEMBER
  COACH
  RECEPTION
  ADMIN
  OWNER
}

model User {
  id        String   @id @default(cuid())
  
  // Tenant Isolation
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // Added for CredentialsProvider fallback
  
  // Custom Registration Properties
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A User is unique per email *per organization* in our custom logic, 
  // but NextAuth standardly keys off the unique `email` field above for simplicity.
  // We remove the composite unique constraint to satisfy NextAuth's default adapter behavior.
  
  name      String?
  phone     String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Membership & Financials
  membershipTier   MembershipTier @default(GUEST)
  status           AccountStatus  @default(ACTIVE)
  stripeCustomerId String?        

  // New Membership Properties
  isLicenseHolder      Boolean @default(false)
  isRegisteredShooter  Boolean @default(false)
  address              String?
  certificateNumber    String?
  
  // File Upload References (Vercel Blob URLs)
  profilePhotoUrl      String?
  certificateUrl       String?
  gunLicenseUrl        String?

  // Document Access Control
  licenseAccessGranted   Boolean @default(false)
  licenseAccessRequested Boolean @default(false)

  // Security Hash for Membership QR
  qrHash               String? @unique

  // E-Wallet (Digital Clays)
  creditBalance        Int @default(0) // Balance in 'Digital Clays' or pennies

  // Relations
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  invoices      Invoice[]
  bookings      Booking[]
  walletTx      WalletTransaction[]
  waitlistEntries WaitlistEntry[]
  recurringTemplates RecurringBookingTemplate[] @relation("TemplateOwner")
  scores        DisciplineScore[]
  coachedSessions CoachingSession[] @relation("MemberCoaching")
  instructorSessions CoachingSession[] @relation("CoachSessions")
  coachingNotes CoachingNote[]
  complianceDocuments ComplianceDocument[]
  incidentsReported IncidentLog[] @relation("IncidentReporter")
  incidentsAssigned IncidentLog[] @relation("IncidentAssignee")
  privacyRequests PrivacyRequest[]
  commCampaigns CommunicationCampaign[] @relation("CampaignAuthor")
}

// ==========================================
// NextAuth Models (Auth.js)
// ==========================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Financial & E-Wallet Models
// ==========================================

enum TransactionType {
  DEPOSIT
  USAGE
  REFUND
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        TransactionType
  amount      Int      // Positives for deposits/refunds, negatives for usage
  description String?  // e.g., "Reloaded 100 Clays", "Shot 50 Clays at Range A"
  
  stripePaymentIntentId String? @unique

  createdAt   DateTime @default(now())
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model Subscription {
  id     String @id @default(cuid())
  userId String 
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String             @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, organizationId])
}

enum InvoiceStatus {
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Invoice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stripeInvoiceId String?       @unique
  amount          Int // Stored in smallest currency unit (e.g., pence)
  currency        String        @default("GBP")
  status          InvoiceStatus @default(OPEN)
  description     String?

  createdAt DateTime @default(now())
}

// ==========================================
// Facility & Booking Models
// ==========================================

model Facility {
  id          String  @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])

  name        String
  description String?
  capacity    Int     @default(1) // Number of lanes, pegs, or total slots

  // Pricing (in pence)
  baseRate   Int @default(0) // Rate for Guests/Probationary
  memberRate Int @default(0) // Discounted rate for Full Members

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
}

model Booking {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  facilityId String?
  facility   Facility? @relation(fields: [facilityId], references: [id])

  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id])

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)

  paymentIntentId String? // Stripe PaymentIntent for standalone bookings
  amountPaid      Int     @default(0)
  
  // Event & Check-in Details
  squadId         String?
  squad           Squad?  @relation(fields: [squadId], references: [id])
  attendeeName    String?
  startStand      String?
  prePaidClays    Int      @default(0)
  prePaidLessons  Boolean  @default(false)
  checkedInAt     DateTime?

  // Event specific QR hash
  qrHash          String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facilityId, startTime, endTime])
}

model RecurringBookingTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User     @relation("TemplateOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  facilityId     String
  facility       Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  title          String
  weekday        Int      // 0 = Sunday ... 6 = Saturday
  startHour      Int
  durationMinutes Int
  maxOccurrences Int?     // Optional safety cap
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==========================================
// Event & CRM Models
// ==========================================

model Event {
  id          String   @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title       String
  description String?
  date        DateTime
  
  signInTime  DateTime?
  startTime   DateTime?
  maxAttendees Int?
  
  eventType   String   @default("COMPETITION") // COMPETITION, CLAYMATE, CORPORATE_EVENT, RESTAURANT, SHOPPING_EVENT, OTHER
  entryFee    Int      @default(0)             // Fee in pennies (E-Wallet credits)
  
  bookings    Booking[]
  squads      Squad[]
  waitlistEntries WaitlistEntry[]
  scores DisciplineScore[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaderboardSeason {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  startsAt       DateTime
  endsAt         DateTime
  discipline     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  scores         DisciplineScore[]
}

model DisciplineScore {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId        String?
  event          Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  seasonId       String?
  season         LeaderboardSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  discipline     String
  score          Float
  handicap       Float?
  recordedAt     DateTime @default(now())
  notes          String?
}

model LessonPackage {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  sessionCount   Int
  price          Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sessions       CoachingSession[]
}

model CoachingSession {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packageId      String?
  package        LessonPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  coachId        String?
  coach          User?    @relation("CoachSessions", fields: [coachId], references: [id], onDelete: SetNull)
  memberId       String
  member         User     @relation("MemberCoaching", fields: [memberId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  durationMinutes Int
  status         String   @default("SCHEDULED")
  notes          CoachingNote[]
}

model CoachingNote {
  id              String   @id @default(cuid())
  coachingSessionId String
  coachingSession CoachingSession @relation(fields: [coachingSessionId], references: [id], onDelete: Cascade)
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body            String
  createdAt       DateTime @default(now())
}

model ComplianceDocument {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String   // CERTIFICATE, LICENSE, INSURANCE
  reference      String?
  expiresAt      DateTime?
  status         String   @default("PENDING")
  reminderSentAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model IncidentLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  severity       String   @default("LOW")
  category       String   @default("SAFETY")
  details        String?
  reportedById   String?
  reportedBy     User?    @relation("IncidentReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     User?    @relation("IncidentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  occurredAt     DateTime @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CommunicationCampaign {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?    @relation("CampaignAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  name           String
  audienceFilter String?
  channel        String   @default("EMAIL")
  status         String   @default("DRAFT")
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PrivacyRequest {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestType    String   // ACCESS_EXPORT, ERASURE, RECTIFICATION
  status         String   @default("OPEN")
  notes          String?
  requestedAt    DateTime @default(now())
  completedAt    DateTime?
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  facilities     Facility[]
}

enum WaitlistStatus {
  WAITING
  OFFERED
  CONFIRMED
  EXPIRED
  CANCELLED
}

model WaitlistEntry {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  requestedTickets Int @default(1)
  status        WaitlistStatus @default(WAITING)
  notes         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId, status, createdAt])
}

model Squad {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  name        String   // e.g. "Squad 1"
  startTime   DateTime?
  maxCapacity Int      @default(6)
  
  bookings    Booking[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// Phase 9: Dynamic Subscription Pricing
// ==========================================

model PlatformPlan {
  id          String   @id @default(cuid())
  name        String   // e.g "Standard SaaS License"
  description String?
  
  monthlyPrice Int      // Stored in pence (£199.00 = 19900)
  annualPrice  Int      // Stored in pence (£1900.00 = 190000)
  
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MembershipPlan {
  id          String   @id @default(cuid())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name        String   // e.g "Full Member", "VIP", "Junior"
  description String?
  
  monthlyPrice Int      // Stored in pence (£45.00 = 4500)
  annualPrice  Int      // Stored in pence (£450.00 = 45000)
  
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([name, organizationId])
}
